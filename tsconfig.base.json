{
	"compilerOptions": {
		"module": "esnext",
		"target": "esnext",
		"outDir": "dist",
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"moduleResolution": "bundler",
		"noUnusedParameters": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"lib": [
            "ES6",
            "ESNext",
            "DOM"
        ],
		"types": ["node"]
	},
}